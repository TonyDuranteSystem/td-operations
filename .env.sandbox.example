# .env.sandbox.example — committed template for the sandbox environment
# Copy to .env.sandbox (gitignored) and fill in sandbox values ONLY.
# NEVER mix sandbox and production values. See CLAUDE.md → Sandbox Environment.

# Sandbox identifier — must match sandbox Supabase project ref
SANDBOX_MODE=1
EXPECTED_SUPABASE_REF=xjcxlmlpeywtwkhstjlw

# Supabase — SANDBOX project only (ref: xjcxlmlpeywtwkhstjlw)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App base URLs — sandbox Vercel preview URL
NEXT_PUBLIC_APP_URL=https://td-operations-git-sandbox-tony-durantes-projects.vercel.app
APP_BASE_URL=https://td-operations-git-sandbox-tony-durantes-projects.vercel.app
PORTAL_BASE_URL=https://td-operations-git-sandbox-tony-durantes-projects.vercel.app

# All other env vars (Google, Stripe, QuickBooks, etc.) can mirror production
# values for read-only integrations, but webhook endpoints MUST NOT point to
# the sandbox URL — see CLAUDE.md safety rules.
