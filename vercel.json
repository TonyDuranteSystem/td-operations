{
  "crons": [
    {
      "path": "/api/qb/refresh",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/sync-drive",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/sync-airtable",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/check-wire-payments",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/ra-renewal-check",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/annual-report-check",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/overdue-payments-report",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/portal-issues",
      "schedule": "0 */1 * * *"
    },
    {
      "path": "/api/cron/email-monitor",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/annual-installments",
      "schedule": "0 10 1 * *"
    },
    {
      "path": "/api/cron/deadline-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/wizard-reminders",
      "schedule": "17 9 * * *"
    },
    {
      "path": "/api/cron/process-jobs",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/invoice-overdue",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/faxage-ss4-confirm",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/portal-digest",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/plaid-sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/mercury-sync?days=7",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/portal-recurring-invoices",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/audit-health-check",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/raw-sql-weekly-report",
      "schedule": "0 12 * * 1"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "t",
          "value": "(?<token>.*)"
        },
        {
          "type": "query",
          "key": "c",
          "value": "(?<code>.*)"
        }
      ],
      "destination": "/offer/:token?c=:code"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "t",
          "value": "(?<token>.*)"
        }
      ],
      "destination": "/offer/:token"
    }
  ],
  "redirects": [
    {
      "source": "/contract.html",
      "has": [
        {
          "type": "query",
          "key": "t",
          "value": "(?<token>.*)"
        }
      ],
      "destination": "/offer/:token/contract",
      "permanent": true
    },
    {
      "source": "/contract-v2.html",
      "destination": "/contract-template.html",
      "permanent": true
    }
  ]
}
