#!/bin/sh

# Load nvm to ensure Node 20 (required by Next.js 14)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh" 2>/dev/null
nvm use default 2>/dev/null || true

# Check if remote is ahead (another machine may have pushed)
git fetch origin main --quiet 2>/dev/null
AHEAD=$(git rev-list HEAD..origin/main --count 2>/dev/null || echo "0")
if [ "$AHEAD" != "0" ] && [ -n "$AHEAD" ]; then
  echo ""
  echo "❌ PUSH BLOCKED — remote is ${AHEAD} commit(s) ahead."
  echo "   Another machine pushed first. Run:"
  echo "   git pull --rebase origin main && npm run build && git push"
  echo ""
  exit 1
fi

# Block hardcoded client-facing domains — use APP_BASE_URL from lib/config.ts
HARDCODED=$(grep -rn "td-operations\.vercel\.app\|offerte\.tonydurante\.us" \
  --include="*.ts" --include="*.tsx" lib/ app/ 2>/dev/null \
  | grep -v "node_modules" \
  | grep -v "lib/config.ts" \
  | grep -v "lib/oauth.ts" \
  | grep -v "lib/mcp/instructions.ts" \
  | grep -v ".well-known" \
  | grep -v "qb/authorize" \
  | grep -v "qb/callback" || true)

if [ -n "$HARDCODED" ]; then
  echo ""
  echo "❌ PUSH BLOCKED — Hardcoded domain found in client-facing code."
  echo "   Use APP_BASE_URL from lib/config.ts instead."
  echo ""
  echo "$HARDCODED"
  echo ""
  exit 1
fi

echo "🔍 Running ESLint on changed files..."
CHANGED_TS=$(git diff --name-only origin/main...HEAD -- '*.ts' '*.tsx' 2>/dev/null)
if [ -n "$CHANGED_TS" ]; then
  echo "$CHANGED_TS" | xargs npx eslint --max-warnings 0 2>&1 | tail -10
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ PUSH BLOCKED — ESLint errors in changed files."
    echo "   Run 'npm run lint:fix' to auto-fix, or fix manually."
    echo ""
    exit 1
  fi
  echo "✅ ESLint passed."
else
  echo "   No .ts/.tsx files changed — skipping lint."
fi

echo "🧪 Running unit tests before push..."
npm run test:unit 2>&1 | tail -5

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ UNIT TESTS FAILED — push blocked."
  echo "   Run 'npm run test:unit' to see failures, fix them, then push again."
  echo ""
  exit 1
fi

echo "🧪 Running integration tests before push (P1.7 characterization)..."
npm run test:integration 2>&1 | tail -5

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ INTEGRATION TESTS FAILED — push blocked."
  echo "   Run 'npm run test:integration' to see failures, fix them, then push again."
  echo ""
  exit 1
fi

echo "🔨 Running build check before push (Node $(node -v))..."
npm run build > /dev/null 2>&1

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ BUILD FAILED — push blocked."
  echo "   Run 'npm run build' to see errors, fix them, then push again."
  echo ""
  exit 1
fi

echo "✅ Tests + build passed — pushing."
